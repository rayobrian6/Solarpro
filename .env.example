# ============================================================
# SolarPro Environment Variables — Template
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git — it contains secrets.
# See DEVELOPMENT.md for where to get each value.
# ============================================================

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Get from https://console.neon.tech → your project → Connection string (pooled)
DATABASE_URL=YOUR_NEON_DATABASE_URL_HERE

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
#
# CRITICAL — Vercel multi-environment setup:
#   Vercel → Project → Settings → Environment Variables → Add JWT_SECRET
#   Check ALL THREE boxes: Production ✓  Preview ✓  Development ✓
#   Use the SAME value for all three environments.
#   If Production and Preview have different secrets, a token signed at login
#   (Production) cannot be verified at /api/auth/me (Preview) → AUTH_COOKIE_MISSING.
#   This is the most common cause of "login works but next page fails" after deploy.
#
# Diagnosis: visit /api/debug/auth after deploy — authSecretFingerprint must match
# the fingerprint logged by [AUTH_SECRET_FINGERPRINT] in the login function logs.
JWT_SECRET=YOUR_JWT_SECRET_HERE

# ── Dev Auth Bypass (PREVIEW / LOCAL DEV ONLY — never activate in production) ──
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  IMPORTANT: NODE_ENV IS NOT RELIABLE ON VERCEL                         │
# │  Vercel sets NODE_ENV=production for ALL deployment types:              │
# │    - Production deployments  (VERCEL_ENV=production)                   │
# │    - Preview deployments     (VERCEL_ENV=preview)   ← development here │
# │    - Vercel CLI dev          (VERCEL_ENV=development)                   │
# │                                                                         │
# │  The auth bypass uses VERCEL_ENV as the production gate, not NODE_ENV.  │
# │  VERCEL_ENV=production → bypass ALWAYS blocked (hard-coded).           │
# │  VERCEL_ENV=preview + DEV_AUTH_BYPASS=true → bypass active.            │
# └─────────────────────────────────────────────────────────────────────────┘
#
# Problem solved:
#   Every preview deployment is a fresh serverless instance. If JWT_SECRET is
#   not set in Vercel Settings for the Preview environment, verifyToken() returns
#   null for every request and you get stuck in a login loop:
#     AUTH_COOKIE_MISSING → AUTH_MIDDLEWARE_BLOCKED → 401 /api/auth/me → redirect
#
# Solution: set DEV_AUTH_BYPASS=true in Vercel Settings (Preview scope only).
#   The bypass returns a fixed super_admin dev user — no JWT cookie needed.
#
# ── Vercel Dashboard Setup (one-time, per project) ───────────────────────
#
#   Step 1: Ensure JWT_SECRET is set for ALL environments:
#     Vercel → Project → Settings → Environment Variables
#     Add JWT_SECRET → set value → check Production ✓ Preview ✓ Development ✓
#     Generate a strong secret:
#       node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
#     CRITICAL: The SAME secret value must be used across all environments.
#     If Production and Preview have different values, tokens signed in one
#     environment cannot be verified in the other.
#
#   Step 2 (optional — bypass instead of fixing JWT_SECRET for preview):
#     Add DEV_AUTH_BYPASS=true → check Preview ✓ Development ✓
#     Leave Production UNCHECKED — bypass must never activate in production.
#
# ── Local dev (.env.local — never commit) ────────────────────────────────
#
# DEV_AUTH_BYPASS=true
# DEV_AUTH_USER_ID=dev-user-001        # optional — default: dev-user-bypass-001
# DEV_AUTH_USER_EMAIL=dev@localhost    # optional — default: dev@localhost
# DEV_AUTH_USER_NAME=Dev User          # optional — default: Dev User (Bypass)
#
# ── Safety guards — bypass is blocked when: ──────────────────────────────
#   VERCEL_ENV=production (Vercel production deployment — hard-coded block)
#   DEV_AUTH_BYPASS not set or not 'true'
#
# ── Verification ─────────────────────────────────────────────────────────
#   After deploying, visit /api/debug/auth to see:
#     devAuthAllowed: true/false
#     devAuthBypassed: true/false
#     jwtSecretSet: true/false
#     authSecretFingerprint: len=XX_head=XXXX_...
#   Search Vercel function logs for [DEV_AUTH_ACTIVE] to confirm bypass is on.

# ── App URL — CRITICAL for password reset links, Stripe callbacks, share URLs ─
#
# Set NEXT_PUBLIC_APP_URL to your PRODUCTION domain in Vercel environment vars.
# Without this, reset links and share URLs will fall back to VERCEL_URL which
# is an ephemeral preview deployment URL and will NOT match your production domain.
#
# In Vercel dashboard → Settings → Environment Variables (Production scope):
#   NEXT_PUBLIC_APP_URL = https://solarpro-v31.vercel.app
#
# This single variable is used by:
#   - lib/env.ts getBaseUrl()         → all password reset email links
#   - lib/stripe.ts                   → Stripe checkout/portal return URLs
#   - lib/billOcrEngine.ts            → internal API call base URL
#   - app/api/proposals/[id]/share/   → proposal share link generation
#
# Local dev:
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Google Maps / Geocoding ───────────────────────────────────────────────────
# Get from https://console.cloud.google.com → APIs → Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# ── Cesium Ion (3D terrain maps) ──────────────────────────────────────────────
# Get from https://cesium.com/ion/tokens
NEXT_PUBLIC_CESIUM_ION_TOKEN=YOUR_CESIUM_ION_TOKEN_HERE

# ── NREL PVWatts (solar production estimates) ─────────────────────────────────
# Get from https://developer.nrel.gov/signup/ — or use DEMO_KEY for dev
NREL_API_KEY=DEMO_KEY

# ── Stripe (billing/subscriptions) ───────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys — use sk_test_* for dev
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY

# Stripe Price IDs — get from https://dashboard.stripe.com/products
# Create one product per plan, copy the Price ID (price_xxxxx) for each.
STRIPE_PRICE_STARTER=price_YOUR_STARTER_PRICE_ID
STRIPE_PRICE_PROFESSIONAL=price_YOUR_PROFESSIONAL_PRICE_ID
STRIPE_PRICE_CONTRACTOR=price_YOUR_CONTRACTOR_PRICE_ID

# ── OpenAI (bill OCR / AI assistant) ─────────────────────────────────────────
# Get from https://platform.openai.com/api-keys — optional for local dev
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# ── Mapbox (map tiles) ────────────────────────────────────────────────────────
# Get from https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=YOUR_MAPBOX_TOKEN_HERE

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get from https://resend.com → API Keys
# Required for password reset emails in production.
# Sender domain: mail.solarpro.app (add Resend DNS records in Gandi.net)
# From address:  noreply@mail.solarpro.app
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE

# ── Database Migrations ───────────────────────────────────────────────────────
# Protects POST /api/db/migrate from unauthorized execution.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In Vercel: set the same value and pass it as { "secret": "..." } in the request body.
MIGRATE_SECRET=YOUR_MIGRATE_SECRET_HERE